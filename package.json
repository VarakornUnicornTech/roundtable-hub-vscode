{
  "name": "roundtable-hub",
  "displayName": "UniOpsQC Hub",
  "description": "Management hub for UniOpsQC Framework — one-click install, visual setup, version management",
  "version": "1.5.0",
  "publisher": "UnicornTech",
  "license": "MIT",
  "icon": "media/logo4.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/VarakornUnicornTech/roundtable-hub-vscode"
  },
  "homepage": "https://github.com/VarakornUnicornTech/roundtable-framework",
  "engines": {
    "vscode": "^1.110.0"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "UniOpsQC",
    "roundtable",
    "claude",
    "claude-code",
    "ai-governance",
    "framework"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "roundtable-hub",
          "title": "UniOpsQC Hub",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "roundtable-hub": [
        {
          "type": "webview",
          "id": "roundtable-hub.sidebar",
          "name": "UniOpsQC Hub"
        }
      ]
    },
    "commands": [
      {
        "command": "roundtable.install",
        "title": "UniOpsQC: Install Framework"
      },
      {
        "command": "roundtable.setup",
        "title": "UniOpsQC: Setup Project"
      },
      {
        "command": "roundtable.checkUpdate",
        "title": "UniOpsQC: Check for Updates"
      },
      {
        "command": "roundtable.update",
        "title": "UniOpsQC: Update Framework"
      },
      {
        "command": "roundtable.pushToHub",
        "title": "UniOpsQC: Push to Hub"
      }
    ],
    "configuration": {
      "title": "UniOpsQC Hub",
      "properties": {
        "roundtable.repoUrl": {
          "type": "string",
          "default": "VarakornUnicornTech/roundtable-framework",
          "description": "GitHub repository for UniOpsQC Framework template"
        },
        "roundtable.licenseKey": {
          "type": "string",
          "default": "",
          "description": "License key for UniOpsQC Hub Pro features"
        },
        "roundtable.autoCheckUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for UniOpsQC framework updates on startup"
        },
        "roundtable.hubApiPath": {
          "type": "string",
          "default": "",
          "description": "Path to Hub.Api project (e.g., D:/AI Projects/Projects/RoundTable-Hub/src/Hub.Api). Auto-detected if empty."
        },
        "roundtable.hubApiUrl": {
          "type": "string",
          "default": "http://localhost:5200",
          "description": "URL of the running RoundTable Hub API server"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build -- --minify",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
